{
  "name": "@aion_charts/aion_charts-wasm",
  "version": "0.1.1",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aion_charts/Aion_charts.git"
  },
  "description": "High-performance Canvas2D charting engine — WASM build",
  "main": "./wasm/pkg/aion_charts_wasm.js",
  "module": "./wasm/pkg/aion_charts_wasm.js",
  "types": "./wasm/pkg/aion_charts_wasm.d.ts",
  "scripts": {
    "build": "node scripts/build-wasm-artifacts.mjs",
    "build:release": "node scripts/build-wasm-artifacts.mjs --release",
    "test:e2e": "playwright test",
    "test:artifacts": "node scripts/check-wasm-artifacts.mjs",
    "prepack": "npm run build:release",
    "serve": "python serve.py",
    "dev": "python dev.py"
  },
  "exports": {
    ".": {
      "types": "./wasm/pkg/aion_charts_wasm.d.ts",
      "import": "./wasm/pkg/aion_charts_wasm.js"
    },
    "./compat": {
      "types": "./wasm/aion_charts-compat.d.ts",
      "import": "./wasm/aion_charts-compat.js"
    },
    "./indicator-worker": {
      "types": "./wasm/indicator-worker.d.ts",
      "import": "./wasm/indicator-worker.js"
    },
    "./aion_charts_wasm_bg.wasm": "./wasm/pkg/aion_charts_wasm_bg.wasm"
  },
  "files": [
    "LICENSE",
    "README.md",
    "wasm/aion_charts-compat.js",
    "wasm/aion_charts-compat.d.ts",
    "wasm/indicator-worker.js",
    "wasm/indicator-worker.d.ts",
    "wasm/pkg/aion_charts_wasm_bg.wasm",
    "wasm/pkg/aion_charts_wasm_bg.wasm.d.ts",
    "wasm/pkg/aion_charts_wasm.js",
    "wasm/pkg/aion_charts_wasm.d.ts"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "chart",
    "charting",
    "canvas",
    "trading",
    "wasm",
    "financial",
    "candlestick"
  ],
  "sideEffects": [
    "./snippets/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
