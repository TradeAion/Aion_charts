{
  "name": "@axiusflow/axiuscharts-wasm",
  "version": "0.1.1",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axiusflow/Axius_charts.git"
  },
  "description": "High-performance Canvas2D charting engine — WASM build",
  "main": "./wasm/pkg/axiuscharts_wasm.js",
  "module": "./wasm/pkg/axiuscharts_wasm.js",
  "types": "./wasm/pkg/axiuscharts_wasm.d.ts",
  "scripts": {
    "build": "wasm-pack build --target web wasm && node -e \"require('fs').writeFileSync('wasm/pkg/.gitignore', '!axiuscharts_wasm_bg.wasm\\n!axiuscharts_wasm_bg.wasm.d.ts\\n!axiuscharts_wasm.d.ts\\n!axiuscharts_wasm.js\\n!package.json\\n')\"",
    "build:release": "wasm-pack build --target web --release wasm && node -e \"require('fs').writeFileSync('wasm/pkg/.gitignore', '!axiuscharts_wasm_bg.wasm\\n!axiuscharts_wasm_bg.wasm.d.ts\\n!axiuscharts_wasm.d.ts\\n!axiuscharts_wasm.js\\n!package.json\\n')\"",
    "test:e2e": "playwright test",
    "test:artifacts": "node scripts/check-wasm-artifacts.mjs",
    "prepack": "npm run build:release",
    "serve": "python serve.py",
    "dev": "python dev.py"
  },
  "exports": {
    ".": {
      "types": "./wasm/pkg/axiuscharts_wasm.d.ts",
      "import": "./wasm/pkg/axiuscharts_wasm.js"
    },
    "./axiuscharts_wasm_bg.wasm": "./wasm/pkg/axiuscharts_wasm_bg.wasm"
  },
  "files": [
    "LICENSE",
    "README.md",
    "wasm/pkg/axiuscharts_wasm_bg.wasm",
    "wasm/pkg/axiuscharts_wasm_bg.wasm.d.ts",
    "wasm/pkg/axiuscharts_wasm.js",
    "wasm/pkg/axiuscharts_wasm.d.ts"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "chart",
    "charting",
    "canvas",
    "trading",
    "wasm",
    "financial",
    "candlestick"
  ],
  "sideEffects": [
    "./snippets/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
