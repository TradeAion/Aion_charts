{
  "name": "@aion/charts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aion Charts public TypeScript API (snake_case, semantics mirror lightweight-charts v5)",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:wasm": "wasm-pack build ../../crates/aion_wasm --target web --out-dir ../../packages/charts/pkg",
    "build:bundle": "esbuild src/index.ts --bundle --format=esm --outfile=../../examples/web_demo/dist/aion_charts.js",
    "build:copy-wasm": "node -e \"const fs=require('fs');fs.mkdirSync('../../examples/web_demo/dist',{recursive:true});fs.copyFileSync('pkg/aion_wasm_bg.wasm','../../examples/web_demo/dist/aion_wasm_bg.wasm')\"",
    "build": "npm run build:wasm && npm run build:bundle && npm run build:copy-wasm"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
