{
  "name": "@aion/charts",
  "version": "0.1.0",
  "type": "module",
  "description": "Aion Charts public TypeScript API (snake_case, semantics mirror lightweight-charts v5)",
  "license": "MIT",
  "author": "TradeAion",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TradeAion/Aion_charts.git",
    "directory": "packages/charts"
  },
  "bugs": "https://github.com/TradeAion/Aion_charts/issues",
  "homepage": "https://github.com/TradeAion/Aion_charts#readme",
  "keywords": [
    "chart",
    "charts",
    "trading",
    "candlestick",
    "finance",
    "webgpu",
    "wasm",
    "rust",
    "lightweight-charts"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/index.js.map"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('pkg',{recursive:true,force:true})\"",
    "build:wasm": "wasm-pack build ../../crates/aion_wasm --target web --out-dir ../../packages/charts/pkg",
    "build:js": "esbuild src/index.ts --bundle --format=esm --sourcemap --outfile=dist/index.js",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist --noEmit false",
    "build:copy-wasm": "node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('pkg/aion_wasm_bg.wasm','dist/aion_wasm_bg.wasm')\"",
    "build": "npm run build:wasm && npm run build:js && npm run build:types && npm run build:copy-wasm",
    "lint": "oxlint src",
    "test:pack": "node scripts/pack_smoke.mjs",
    "prepublishOnly": "npm run clean && npm run build && npm run test:pack"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2"
  }
}
